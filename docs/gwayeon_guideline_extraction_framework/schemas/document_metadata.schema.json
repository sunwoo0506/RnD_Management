{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwayeon.local/schemas/document_metadata.schema.json",
  "title": "Guideline Document Metadata",
  "type": "object",
  "required": [
    "document_id",
    "title",
    "document_type",
    "issuer",
    "version_code",
    "publication_status",
    "source_file_hash"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "document_type": {
      "type": "string"
    },
    "issuer": {
      "type": "string"
    },
    "notice_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "promulgated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "effective_from": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "effective_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "version_code": {
      "type": "string"
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "ACTIVE",
        "SUPERSEDED",
        "REPEALED",
        "UNKNOWN"
      ]
    },
    "scope": {
      "type": "object",
      "properties": {
        "ministries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "programs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "institution_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_file_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "source_filename": {
      "type": "string"
    },
    "source_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "special_effective_dates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target",
          "effective_from"
        ],
        "properties": {
          "target": {
            "type": "string"
          },
          "effective_from": {
            "type": "string",
            "format": "date"
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}